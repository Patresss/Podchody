# Skopiuj ten plik jako .env i zmień wszystkie wartości.
PORT=3000
NODE_ENV=development
DATA_DIR=./data
ADMIN_USERNAME=admin

# Wygeneruj po zbudowaniu obrazu:
# docker compose run --rm app node apps/server/dist/hash-password-cli.js
# Brak wartości celowo uniemożliwi uruchomienie aplikacji.
ADMIN_PASSWORD_HASH=

# Co najmniej 32 losowe znaki, np. openssl rand -hex 32
SESSION_SECRET=

# Ustaw true tylko gdy aplikacja jest wystawiona przez HTTPS.
COOKIE_SECURE=false

# Liczba zaufanych reverse proxy przed aplikacją; 1 dla typowego Caddy/Nginx.
TRUST_PROXY_HOPS=1
